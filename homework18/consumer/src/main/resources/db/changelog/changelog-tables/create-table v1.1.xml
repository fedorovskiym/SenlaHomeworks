<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.31.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1773577292068-2" author="fedor">
        <createTable tableName="transfer">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_transfer"/>
            </column>
            <column name="from_account_id" type="BIGINT"/>
            <column name="target_account_id" type="BIGINT"/>
            <column name="amount" type="INT"/>
            <column name="transfer_status" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="1773577292068-3" author="fedor">
        <addForeignKeyConstraint baseColumnNames="from_account_id" baseTableName="transfer"
                                 constraintName="FK_TRANSFER_ON_FROM_ACCOUNT" referencedColumnNames="id"
                                 referencedTableName="account"/>
    </changeSet>
    <changeSet id="1773577292068-4" author="fedor">
        <addForeignKeyConstraint baseColumnNames="target_account_id" baseTableName="transfer"
                                 constraintName="FK_TRANSFER_ON_TARGET_ACCOUNT" referencedColumnNames="id"
                                 referencedTableName="account"/>
    </changeSet>

</databaseChangeLog>